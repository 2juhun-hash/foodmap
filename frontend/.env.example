# Kakao Maps — 서버 전용 (절대 NEXT_PUBLIC_ 사용 금지)
KAKAO_REST_API_KEY=

# Kakao Maps JS SDK — 클라이언트 노출됨. Kakao Developers에서 도메인 제한 설정 필수
NEXT_PUBLIC_KAKAO_JS_KEY=

# Backend API URL (배포 시 Railway/Render 백엔드 URL로 교체)
NEXT_PUBLIC_API_URL=https://your-backend.railway.app

# Mock 모드 — true 시 백엔드 없이 data/mock.json 사용
NEXT_PUBLIC_USE_MOCK=false
